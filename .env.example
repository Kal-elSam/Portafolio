# MongoDB (Prisma)
DATABASE_URL=mongodb://localhost:27017/portfolio

# Hashing de sesiones/IP para views y reactions
SALT_IP_ADDRESS=change-me-to-a-random-secret

# Vercel (inyectadas automáticamente en deploy)
NEXT_PUBLIC_VERCEL_ENV=development
NEXT_PUBLIC_VERCEL_URL=localhost:3000

# Bundle analyzer (opcional)
ANALYZE=false

# Node
NODE_ENV=development
